#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import shlex
import sys
import subprocess
from datetime import datetime, timezone, timedelta
from pathlib import Path
import time

SWITCHER_DIR = Path.home() / ".claude-switcher"
ACCOUNTS_DIR = SWITCHER_DIR / "accounts"
CLAUDE_JSON = Path.home() / ".claude.json"
KEYCHAIN_SERVICE = "Claude Code-credentials"
SWITCHER_KEYCHAIN_SERVICE = "Claude Code-switcher"
CREDENTIAL_VERSION = 2

RED    = '\033[0;31m'
GREEN  = '\033[0;32m'
YELLOW = '\033[1;33m'
CYAN   = '\033[0;36m'
BOLD   = '\033[1m'
DIM    = '\033[2m'
NC     = '\033[0m'

def setup():
    ACCOUNTS_DIR.mkdir(parents=True, exist_ok=True)
    SWITCHER_DIR.chmod(0o700)
    ACCOUNTS_DIR.chmod(0o700)

def read_claude_json():
    with open(CLAUDE_JSON) as f:
        return json.load(f)

def write_claude_json(data):
    tmp = CLAUDE_JSON.with_suffix('.json.tmp')
    with open(tmp, 'w') as f:
        json.dump(data, f, indent=2)
    tmp.replace(CLAUDE_JSON)

def get_current_account():
    try:
        return read_claude_json().get('oauthAccount', {})
    except Exception:
        return {}

def get_keychain_credentials():
    result = subprocess.run(
        ['security', 'find-generic-password', '-l', KEYCHAIN_SERVICE, '-w'],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        return result.stdout.strip() or None
    return None

def set_keychain_credentials(credentials: str) -> bool:
    subprocess.run(
        ['security', 'delete-generic-password', '-l', KEYCHAIN_SERVICE],
        capture_output=True
    )
    result = subprocess.run(
        ['security', 'add-generic-password',
         '-a', os.environ.get('USER', 'user'),
         '-s', KEYCHAIN_SERVICE,
         '-w', credentials],
        capture_output=True, text=True
    )
    return result.returncode == 0

# --- per-profile Keychain helpers ---

def get_profile_credentials(email: str):
    result = subprocess.run(
        ['security', 'find-generic-password',
         '-s', SWITCHER_KEYCHAIN_SERVICE, '-a', email, '-w'],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        return result.stdout.strip() or None
    return None

def set_profile_credentials(email: str, credentials: str) -> bool:
    subprocess.run(
        ['security', 'delete-generic-password',
         '-s', SWITCHER_KEYCHAIN_SERVICE, '-a', email],
        capture_output=True
    )
    result = subprocess.run(
        ['security', 'add-generic-password',
         '-s', SWITCHER_KEYCHAIN_SERVICE,
         '-a', email,
         '-w', credentials],
        capture_output=True, text=True
    )
    return result.returncode == 0

def delete_profile_credentials(email: str):
    subprocess.run(
        ['security', 'delete-generic-password',
         '-s', SWITCHER_KEYCHAIN_SERVICE, '-a', email],
        capture_output=True
    )

# --- session helpers ---

def project_dir_name(path: str) -> str:
    return path.replace('/', '-')

def get_last_session(project_path: str | None = None) -> dict | None:
    projects_dir = Path.home() / ".claude" / "projects"
    if not projects_dir.exists():
        return None

    if project_path:
        encoded = project_dir_name(project_path)
        search_dirs = [projects_dir / encoded]
    else:
        search_dirs = [d for d in projects_dir.iterdir() if d.is_dir()]

    latest_file = None
    latest_mtime = 0

    for proj_dir in search_dirs:
        if not proj_dir.exists():
            continue
        for f in proj_dir.glob("*.jsonl"):
            mtime = f.stat().st_mtime
            if mtime > latest_mtime:
                latest_mtime = mtime
                latest_file = f

    if latest_file:
        return {
            'session_id': latest_file.stem,
            'project_path': project_path or str(latest_file.parent.name),
            'saved_at': time.time(),
        }
    return None

# --- profile file helpers ---

def account_filename(email: str) -> Path:
    safe = email.replace('@', '_at_').replace('.', '_').replace('+', '_')
    return ACCOUNTS_DIR / f"{safe}.json"

def list_saved_accounts():
    if not ACCOUNTS_DIR.exists():
        return []
    accounts = []
    for f in sorted(ACCOUNTS_DIR.glob('*.json')):
        try:
            profile = json.loads(f.read_text())
            accounts.append(profile)
        except Exception:
            pass
    return sorted(accounts, key=lambda x: x.get('email', ''))

USAGE_CACHE = SWITCHER_DIR / "usage_cache.json"
USAGE_CACHE_TTL = 60  # 1 minute

def fetch_live_usage() -> dict | None:
    credentials = get_keychain_credentials()
    if not credentials:
        return None
    try:
        data = json.loads(credentials)
        access_token = data.get('claudeAiOauth', {}).get('accessToken', '')
    except Exception:
        return None
    if not access_token:
        return None

    # Return cached data if still fresh
    try:
        if USAGE_CACHE.exists():
            cached = json.loads(USAGE_CACHE.read_text())
            if time.time() - cached.get('_cached_at', 0) < USAGE_CACHE_TTL:
                return cached
    except Exception:
        pass

    import urllib.request, urllib.error
    req = urllib.request.Request(
        'https://api.anthropic.com/api/oauth/usage',
        headers={
            'Authorization': f'Bearer {access_token}',
            'Content-Type': 'application/json',
            'User-Agent': 'claude-code/2.1.117',
            'anthropic-beta': 'oauth-2025-04-20',
        }
    )
    try:
        with urllib.request.urlopen(req, timeout=8) as r:
            result = json.loads(r.read().decode())
            result['_cached_at'] = time.time()
            try:
                USAGE_CACHE.write_text(json.dumps(result))
                USAGE_CACHE.chmod(0o600)
            except Exception:
                pass
            return result
    except Exception:
        # Fall back to stale cache if available
        try:
            if USAGE_CACHE.exists():
                return json.loads(USAGE_CACHE.read_text())
        except Exception:
            pass
        return None

def format_reset_time(resets_at: str | None) -> str:
    if not resets_at:
        return ''
    try:
        dt = datetime.fromisoformat(resets_at.replace('Z', '+00:00'))
        local = dt.astimezone()
        now = datetime.now(local.tzinfo)
        if local.date() == now.date():
            return local.strftime('Resets %I:%M%p').replace(' 0', ' ').lower()
        return local.strftime(f'Resets %b %-d at %I:%M%p').replace(' 0', ' ').lower()
    except Exception:
        return ''

def render_bar(pct: float, width: int = 50) -> str:
    filled = int(round(pct / 100 * width))
    filled = max(0, min(filled, width))
    bar = '█' * filled + '░' * (width - filled)
    return bar

